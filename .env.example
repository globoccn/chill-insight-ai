VITE_API_URL=https://ancar-n8n.gpfgqx.easypanel.host/webhook
PORT=8003
VITE_AI_AGENT_URL=/api/cag-bot

# Webhooks n8n usados pelo botão de download de relatórios PDF.
# Se não forem definidos, o backend usa os defaults abaixo:
# day   -> cag-relatorio-diario
# week  -> cag-relatorio-semanal
# month -> cag-relatorio-mensal
N8N_REPORT_DAILY_PATH=cag-relatorio-diario
N8N_REPORT_WEEKLY_PATH=cag-relatorio-semanal
N8N_REPORT_MONTHLY_PATH=cag-relatorio-mensal
